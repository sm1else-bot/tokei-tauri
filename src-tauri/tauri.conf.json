{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tokei",
  "version": "0.1.3",
  "identifier": "com.jessenth.tokei",
  "build": {
    "beforeDevCommand": "python -m http.server 4299 --bind 127.0.0.1 --directory ../src",
    "devUrl": "http://127.0.0.1:4299",
    "frontendDist": "../src",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Tokei",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "backgroundColor": "#101216"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Jessenth",
    "copyright": "Copyright (c) 2026 Jessenth",
    "homepage": "https://jessenth.com",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "both",
        "displayLanguageSelector": false
      }
    }
  }
}
